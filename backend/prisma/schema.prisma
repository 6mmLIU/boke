// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String   // 笔名
  handle    String   @unique // @用户名
  previousHandle String? @unique
  password  String?  // 哈希密码 (OAuth 用户可能为空)
  bio       String?  // 个人简介
  avatar    String?  // 头像URL
  role      String   @default("USER")
  isBanned  Boolean  @default(false)
  bannedAt  DateTime?
  bannedReason String?
  handleChangedAt DateTime?

  // 关系
  articles      Article[]
  comments      Comment[]
  likes         Like[]
  bookmarks     Bookmark[]
  followers     Follow[]        @relation("follower")
  following     Follow[]        @relation("following")
  oauthAccounts OAuthAccount[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

// 邮箱验证码（用于注册时验证）
model EmailVerificationCode {
  id        String   @id @default(uuid())
  email     String
  code      String   // 6 位数字
  purpose   String   @default("register") // register / reset
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@map("email_verification_codes")
}

// OAuth 第三方登录账号（GitHub / Google / 微信）
model OAuthAccount {
  id                String   @id @default(uuid())
  provider          String   // github / google / wechat
  providerAccountId String   // 第三方平台返回的用户 ID

  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 缓存的展示信息（首次登录时填充）
  email             String?
  name              String?
  avatar            String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model Article {
  id        String   @id @default(uuid())
  title     String
  titleEn   String?  // 英文标题
  excerpt   String   // 摘要
  content   String   // Markdown/HTML内容
  cover     String   // 封面类型: warm/moss/indigo/cream

  tags      String[]  // 标签数组

  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  likes     Like[]
  comments  Comment[]
  bookmarks Bookmark[]

  views     Int       @default(0) // 阅读数
  readTime  Int       // 阅读时间(分钟)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("articles")
}

model Comment {
  id        String   @id @default(uuid())
  text      String   // 评论内容

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  likes     Int      @default(0)

  createdAt DateTime @default(now())

  @@map("comments")
}

model Like {
  id        String @id @default(uuid())

  authorId  String
  author    User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([authorId, articleId]) // 每个用户只能点赞一次
  @@map("likes")
}

model Follow {
  followerId  String
  follower    User   @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)

  followingId String
  following   User   @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

model Bookmark {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@map("bookmarks")
}
