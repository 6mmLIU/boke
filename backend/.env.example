# ─── 数据库 ───
DATABASE_URL="postgresql://inkwell:inkwell_local_pw@localhost:5432/inkwell?schema=public"

# ─── JWT ───
# 生成: openssl rand -hex 32
JWT_SECRET="change-this-to-a-32-byte-random-hex-string"

# ─── 服务 ───
FRONTEND_URL="http://localhost:8080"
BACKEND_PUBLIC_URL="http://localhost:3001"
PORT=3001
NODE_ENV=development

# ─── 邮箱验证码 (QQ SMTP) ───
# 登录 QQ 邮箱 → 设置 → 账户 → 开启 IMAP/SMTP 服务,获取 16 位授权码
SMTP_USER=""        # 你的 QQ 邮箱完整地址 (例如 12345@qq.com)
SMTP_PASS=""        # 16 位 QQ 邮箱授权码 (不是 QQ 密码!)
SMTP_FROM=""        # 可选:发件人显示,例如 "砚 Inkwell <12345@qq.com>"

# ─── GitHub OAuth ───
# https://github.com/settings/developers → New OAuth App
# Homepage URL:                http://localhost:8080
# Authorization callback URL:  http://localhost:3001/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
